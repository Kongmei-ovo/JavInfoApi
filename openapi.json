{
  "openapi": "3.0.3",
  "info": {
    "title": "JavInfoApi",
    "description": "媒体元数据查询 API，基于 r18.dev 数据库（PostgreSQL）",
    "version": "1.1.0"
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "本地开发服务器"
    }
  ],
  "paths": {
    "/api/v1/videos/search": {
      "get": {
        "summary": "搜索视频",
        "description": "多条件组合搜索视频。release_date_from/release_date_to 必须为 YYYY-MM-DD 格式，否则返回 400",
        "operationId": "searchVideos",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "description": "关键词搜索（匹配 title_en、title_ja、comment_en、comment_ja）",
            "schema": { "type": "string" }
          },
          {
            "name": "content_id",
            "in": "query",
            "description": "内容ID精确匹配",
            "schema": { "type": "string" }
          },
          {
            "name": "dvd_id",
            "in": "query",
            "description": "DVD编号（自动处理横杠，不区分大小写）",
            "schema": { "type": "string" }
          },
          {
            "name": "maker_id",
            "in": "query",
            "description": "厂商ID（精确匹配，优先于 maker_name）",
            "schema": { "type": "integer" }
          },
          {
            "name": "maker_name",
            "in": "query",
            "description": "厂商名称（模糊匹配 name_en/name_ja）",
            "schema": { "type": "string" }
          },
          {
            "name": "series_id",
            "in": "query",
            "description": "系列ID（精确匹配，优先于 series_name）",
            "schema": { "type": "integer" }
          },
          {
            "name": "series_name",
            "in": "query",
            "description": "系列名称（模糊匹配 name_en/name_ja）",
            "schema": { "type": "string" }
          },
          {
            "name": "actress_id",
            "in": "query",
            "description": "演员ID（精确匹配，优先于 actress_name）",
            "schema": { "type": "integer" }
          },
          {
            "name": "actress_name",
            "in": "query",
            "description": "演员名称（模糊匹配 name_romaji/name_kanji/name_kana）",
            "schema": { "type": "string" }
          },
          {
            "name": "category_id",
            "in": "query",
            "description": "分类ID（精确匹配，优先于 category_name）",
            "schema": { "type": "integer" }
          },
          {
            "name": "category_name",
            "in": "query",
            "description": "分类名称（模糊匹配 name_en/name_ja）",
            "schema": { "type": "string" }
          },
          {
            "name": "label_id",
            "in": "query",
            "description": "品牌ID（精确匹配，优先于 label_name）",
            "schema": { "type": "integer" }
          },
          {
            "name": "label_name",
            "in": "query",
            "description": "品牌名称（模糊匹配 name_en/name_ja）",
            "schema": { "type": "string" }
          },
          {
            "name": "site_id",
            "in": "query",
            "description": "站点ID（1=DMM.com, 2=FANZA）",
            "schema": { "type": "integer" }
          },
          {
            "name": "year",
            "in": "query",
            "description": "发行年份（精确匹配，优先于 year_from/year_to）",
            "schema": { "type": "integer" }
          },
          {
            "name": "year_from",
            "in": "query",
            "description": "发行年份起始（含）",
            "schema": { "type": "integer" }
          },
          {
            "name": "year_to",
            "in": "query",
            "description": "发行年份结束（含）",
            "schema": { "type": "integer" }
          },
          {
            "name": "runtime_min",
            "in": "query",
            "description": "最小时长（分钟）",
            "schema": { "type": "integer" }
          },
          {
            "name": "runtime_max",
            "in": "query",
            "description": "最大时长（分钟）",
            "schema": { "type": "integer" }
          },
          {
            "name": "release_date_from",
            "in": "query",
            "description": "发售日期起始（YYYY-MM-DD，含）",
            "schema": { "type": "string", "format": "date" }
          },
          {
            "name": "release_date_to",
            "in": "query",
            "description": "发售日期结束（YYYY-MM-DD，含）",
            "schema": { "type": "string", "format": "date" }
          },
          {
            "name": "service_code",
            "in": "query",
            "description": "服务代码筛选（digital/mono/rental/ebook），空值不过滤",
            "schema": { "type": "string" }
          },
          {
            "name": "page",
            "in": "query",
            "description": "页码，从1开始",
            "schema": { "type": "integer", "default": 1 }
          },
          {
            "name": "page_size",
            "in": "query",
            "description": "每页数量",
            "schema": { "type": "integer", "default": 20, "maximum": 100 }
          },
          {
            "name": "sort_by",
            "in": "query",
            "description": "排序字段及方向，格式：field1:asc,field2:desc（release_date/content_id/dvd_id/title_en/title_ja/runtime_mins），默认ASC",
            "schema": { "type": "string" }
          },
          {
            "name": "random",
            "in": "query",
            "description": "随机返回（random=1），与sort_by互斥",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/VideoListResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/videos": {
      "get": {
        "summary": "视频列表",
        "description": "获取视频分页列表",
        "operationId": "listVideos",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "default": 1 }
          },
          {
            "name": "page_size",
            "in": "query",
            "schema": { "type": "integer", "default": 20, "maximum": 100 }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/VideoListResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/videos/{content_id}": {
      "get": {
        "summary": "视频详情",
        "description": "获取单个视频的完整信息",
        "operationId": "getVideo",
        "parameters": [
          {
            "name": "content_id",
            "in": "path",
            "required": true,
            "description": "视频内容ID",
            "schema": { "type": "string" }
          },
          {
            "name": "service_code",
            "in": "query",
            "description": "服务代码筛选",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/VideoDetailResponse" }
              }
            }
          },
          "400": {
            "description": "content_id 为空",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "404": {
            "description": "视频不存在",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/videos/batch": {
      "post": {
        "summary": "批量获取视频详情",
        "description": "根据 content_id 列表批量获取视频完整信息（含关联数据），最多100个",
        "operationId": "batchGetVideos",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["ids"],
                "properties": {
                  "ids": {
                    "type": "array",
                    "items": { "type": "string" },
                    "maxItems": 100,
                    "description": "content_id 列表"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/VideoDetailResponse" }
                }
              }
            }
          },
          "400": {
            "description": "请求参数错误",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/videos/lookup": {
      "post": {
        "summary": "批量番号查找视频",
        "description": "根据 dvd_id 列表批量查找视频（自动处理横杠和大小写），最多100个。返回 dvd_id -> video 的映射",
        "operationId": "batchLookupVideos",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["dvd_ids"],
                "properties": {
                  "dvd_ids": {
                    "type": "array",
                    "items": { "type": "string" },
                    "maxItems": 100,
                    "description": "dvd_id 列表（支持 ABC-001 或 ABC001 格式）"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功，返回 {dvd_id: video} 映射",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": { "$ref": "#/components/schemas/VideoDetailResponse" }
                }
              }
            }
          },
          "400": {
            "description": "请求参数错误",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/actresses": {
      "get": {
        "summary": "演员列表",
        "description": "获取演员分页列表",
        "operationId": "listActresses",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "description": "关键词搜索（匹配 name_romaji/name_kanji/name_kana）",
            "schema": { "type": "string" }
          },
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "default": 1 }
          },
          {
            "name": "page_size",
            "in": "query",
            "schema": { "type": "integer", "default": 20, "maximum": 100 }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ActressListResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/actresses/{id}": {
      "get": {
        "summary": "演员详情",
        "description": "获取单个演员的信息",
        "operationId": "getActress",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "演员ID",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ActressDetailResponse" }
              }
            }
          },
          "400": {
            "description": "id 不是正整数",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "404": {
            "description": "演员不存在",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/actresses/{id}/videos": {
      "get": {
        "summary": "演员作品列表",
        "description": "获取某演员出演的所有视频",
        "operationId": "getActressVideos",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "演员ID",
            "schema": { "type": "integer" }
          },
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "default": 1 }
          },
          {
            "name": "page_size",
            "in": "query",
            "schema": { "type": "integer", "default": 20, "maximum": 100 }
          },
          {
            "name": "service_code",
            "in": "query",
            "description": "服务代码筛选（digital/mono/rental/ebook），空值不过滤",
            "schema": { "type": "string" }
          },
          {
            "name": "year",
            "in": "query",
            "description": "发行年份筛选",
            "schema": { "type": "integer" }
          },
          {
            "name": "maker_id",
            "in": "query",
            "description": "厂商ID（精确匹配，优先于 maker_name）",
            "schema": { "type": "integer" }
          },
          {
            "name": "maker_name",
            "in": "query",
            "description": "厂商名称（模糊匹配）",
            "schema": { "type": "string" }
          },
          {
            "name": "category_id",
            "in": "query",
            "description": "分类ID（精确匹配，优先于 category_name）",
            "schema": { "type": "integer" }
          },
          {
            "name": "category_name",
            "in": "query",
            "description": "分类名称（模糊匹配）",
            "schema": { "type": "string" }
          },
          {
            "name": "sort_by",
            "in": "query",
            "description": "排序字段及方向，格式：field:dir（release_date/content_id/dvd_id/title_en/title_ja/runtime_mins）",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/VideoListResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/actresses/batch_videos": {
      "post": {
        "summary": "批量获取演员作品",
        "description": "根据演员ID列表批量获取作品，最多20个演员。返回 actress_id -> {total_count, videos} 映射",
        "operationId": "batchActressVideos",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["ids"],
                "properties": {
                  "ids": {
                    "type": "array",
                    "items": { "type": "integer" },
                    "maxItems": 20,
                    "description": "演员ID列表"
                  },
                  "page": {
                    "type": "integer",
                    "default": 1,
                    "description": "页码"
                  },
                  "page_size": {
                    "type": "integer",
                    "default": 20,
                    "maximum": 100,
                    "description": "每页数量"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功，返回 {actress_id: {total_count, videos}} 映射",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "object",
                    "properties": {
                      "total_count": { "type": "integer" },
                      "videos": {
                        "type": "array",
                        "items": { "$ref": "#/components/schemas/VideoSummary" }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "请求参数错误",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/makers": {
      "get": {
        "summary": "厂商列表",
        "description": "获取制作厂商分页列表",
        "operationId": "listMakers",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "description": "关键词搜索（匹配 name_en/name_ja）",
            "schema": { "type": "string" }
          },
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "default": 1 }
          },
          {
            "name": "page_size",
            "in": "query",
            "schema": { "type": "integer", "default": 20, "maximum": 100 }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MakerListResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/labels": {
      "get": {
        "summary": "品牌列表",
        "description": "获取品牌分页列表",
        "operationId": "listLabels",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "description": "关键词搜索（匹配 name_en/name_ja）",
            "schema": { "type": "string" }
          },
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "default": 1 }
          },
          {
            "name": "page_size",
            "in": "query",
            "schema": { "type": "integer", "default": 20, "maximum": 100 }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/LabelListResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/series": {
      "get": {
        "summary": "系列列表",
        "description": "获取影片系列分页列表",
        "operationId": "listSeries",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "description": "关键词搜索（匹配 name_en/name_ja）",
            "schema": { "type": "string" }
          },
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "default": 1 }
          },
          {
            "name": "page_size",
            "in": "query",
            "schema": { "type": "integer", "default": 20, "maximum": 100 }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SeriesListResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/categories": {
      "get": {
        "summary": "题材分类列表",
        "description": "获取题材分类分页列表",
        "operationId": "listCategories",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "description": "关键词搜索（匹配 name_en/name_ja）",
            "schema": { "type": "string" }
          },
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "default": 1 }
          },
          {
            "name": "page_size",
            "in": "query",
            "schema": { "type": "integer", "default": 20, "maximum": 100 }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CategoryListResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/categories/stats": {
      "get": {
        "summary": "题材分类统计",
        "description": "获取所有题材分类及其在影片中的累计出现次数，按video_count降序排序",
        "operationId": "getCategoryStats",
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/CategoryWithCount" }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/stats": {
      "get": {
        "summary": "统计数据",
        "description": "获取数据库统计信息",
        "operationId": "getStats",
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StatsResponse" }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "summary": "健康检查",
        "description": "检查服务状态和数据库连接",
        "operationId": "healthCheck",
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HealthResponse" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "VideoListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/VideoSummary" }
          },
          "page": { "type": "integer" },
          "page_size": { "type": "integer" },
          "total_count": { "type": "integer" },
          "total_pages": { "type": "integer" }
        }
      },
      "VideoSummary": {
        "type": "object",
        "properties": {
          "content_id": { "type": "string" },
          "dvd_id": { "type": "string" },
          "title_en": { "type": "string" },
          "title_ja": { "type": "string" },
          "runtime_mins": { "type": "integer" },
          "release_date": { "type": "string", "format": "date" },
          "jacket_thumb_url": { "type": "string" },
          "site_id": { "type": "integer" },
          "service_code": { "type": "string" }
        }
      },
      "VideoDetailResponse": {
        "type": "object",
        "properties": {
          "content_id": { "type": "string" },
          "dvd_id": { "type": "string" },
          "title_en": { "type": "string" },
          "title_ja": { "type": "string" },
